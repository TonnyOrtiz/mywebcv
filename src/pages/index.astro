---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import Socials from "../components/Socials.astro";
import GlassBox from "../components/container/GlassBox.astro";
import BtnBlue from "../components/btn/Blue.astro";
import BtnGeneric from "../components/btn/Generic.astro";
import { getEntry } from "astro:content";
import FullBox from "../components/container/FullBox.astro";

const technologies = await getCollection("technologies");
const dataEngineering = await getEntry("categories", "dataengineering");
const softwareDevelopment = await getEntry("categories", "softwaredevelopment");
const cloudInfrastructure = await getEntry("categories", "cloudinfrastructure");
const allProjects = await getCollection("projects");
const mainProject = allProjects.find((p) => p.data.isMain);
const secondaryProjects = allProjects.filter((p) => !p.data.isMain).slice(0, 3);
console.log("DEBUG ALL_PROJECTS:", JSON.stringify(allProjects, null, 2));
console.log(dataEngineering?.data.skills);
console.log(technologies[0].data.projects);

const allExperiences = await getCollection("experience");
const mainExperience = allExperiences.find((e) => e.data.isMain);
const secondaryExperiences = allExperiences.filter((e) => !e.data.isMain);

export const prerender = true;

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout title="Home">
	<main
		class="flex flex-col px-6
		md:px-18 md:gap-15 md:mb-15
		xl:px-18 xl:gap-24 xl:mb-48 xl:self-center"
	>
		<section
			id="profile"
			class="max-w-7xl mx-auto w-full pt-14 lg:pt-14"
			aria-label="Profile"
		>
			<h2
				class="text-xl md:text-2xl uppercase tracking-[0.2em] text-gray-500 dark:text-slate-200 py-8 px-2 flex items-center gap-2
				relative w-fit
				lg:animate-blurred-fade-in lg:animate-duration-200 lg:animate-delay-200"
			>
				<div
					class="absolute inset-0 bg-bg/10 blur-xl overflow-visible -z-10"
				>
				</div>
				<span
					class="w-2 h-2 rounded-full bg-violet-500 shadow-[0_0_8px_rgba(249,115,22,0.5)]"
				></span>
				Profile
			</h2>
			<div id="scroller" class="grid grid-cols-1
				gap-6
				lg:grid-cols-16">
				<section
					id="personalSubsection"
					class="grid gap-4 grid-cols-3 grid-rows-2 grid-flow-col
					sm:grid-flow-row
					md:gap-6
					lg:order-2 lg:grid-rows-3 lg:grid-cols-2 lg:col-span-8
					xl:grid-rows-3 xl:grid-cols-2 xl:col-span-7
					2xl:grid-cols-2 2xl:grid-rows-3"
				>
					<GlassBox
						class="bg-[url(/src/assets/profile/purple.webp)] bg-cover bg-top
						contrast-115 brightness-105 dark:brightness-90 dark:contrast-120
						col-span-2
						sm:col-span-1
						md:row-span-1 md:col-span-1
						lg:row-span-2 lg:col-span-1 lg:animate-blurred-fade-in lg:animate-duration-300 ease-in lg:animate-delay-000
						2xl:row-span-2 2xl:col-span-1"
					/>
					<GlassBox
						class="flex flex-col justify-center items-center col-span-2
						sm:col-span-2
						md:row-span-1 md:col-span-2
						lg:p-0 lg:row-span-2 lg:col-span-1 lg:animate-blurred-fade-in lg:animate-duration-300 ease-in lg:animate-delay-100
						2xl:row-span-2 2xl:col-span-1"
					>
						<div
							class="flex flex-col flex-1 justify-center items-center py-none
							sm:flex-row sm:justify-center sm:items-center
							lg:flex-col lg:gap-0 lg:items-center
							2xl:justify-center 2xl:items-center"
						>
							<article
								class="flex flex-col flex-3 justify-center items-center prose prose-sm py-2
								sm:p-6 sm:items-start
								lg:flex-1 lg:py-4 lg:prose-base lg:items-center lg:pb-0
								xl:prose-lg
								2xl:flex-3"
							>
								<h3
									class="font-semibold text-font-primary mb-0 pb-0 md:pl-0"
								>
									@TonnyOrtiz
								</h3>
								<span
									class="md:pl-0 text-font-primary whitespace-nowrap
								text-center"
								>
									B.S. in Computer Science
								</span>
								<span
									class="md:pl-0 text-font-primary whitespace-nowrap
								text-center"
								>
									Guanacaste, CR 🇨🇷
								</span>
							</article>
							<div
								class="pb-2
								sm:pr-6
								md:pb-0
								lg:pb-6 lg:pr-0
								2xl:pb-10"
							>
								<Socials />
							</div>
						</div>
					</GlassBox>
					<div
						class="grid gap-4 grid-rows-3 row-span-2 col-span-1
						sm:col-span-3 sm:grid-rows-1 sm:grid-cols-3 sm:row-span-1
						md:gap-6 md:grid-rows-1 md:grid-cols-3
						lg:row-span-1 lg:col-span-2 lg:grid-cols-3 lg:grid-rows-1
						2xl:grid-cols-3 2xl:grid-rows-1 2xl:col-span-2 2xl:row-span-1"
					>
						<GlassBox
							class="flex flex-col justify-center items-center
							lg:animate-blurred-fade-in lg:animate-duration-300 ease-in lg:animate-delay-100"
						>
							<span
								class="text-font-primary text-3xl text-center
								md:text-4xl 2xl:text-5xl"
								>3+</span
							>
							<span
								class="text-font-primary text-sm px-4 text-center
								md:text-md 2xl:text-lg"
								>years experience</span
							>
						</GlassBox>
						<GlassBox
							class="flex flex-col justify-center items-center
							lg:animate-blurred-fade-in lg:animate-duration-300 ease-in lg:animate-delay-150"
							><svg
								class="w-full h-24 opacity-90 dark:opacity-90 p-6 text-font-primary"
							>
								<use xlink:href="/sprite.svg#ucr"></use>
							</svg>
						</GlassBox>
						<GlassBox
							class="justify-center items-center flex flex-col
							lg:animate-blurred-fade-in lg:animate-duration-300 ease-in lg:animate-delay-200"
						>
							<span
								class="text-font-primary text-3xl text-center
								md:text-4xl 2xl:text-5xl"
								>4+</span
							>
							<span
								class="text-font-primary text-sm px-4 text-center
								md:text-md 2xl:text-lg"
								>projects</span
							>
						</GlassBox>
					</div>
				</section>

				<GlassBox
					class="flex flex-col justify-center items-center md:col-span-1
					lg:order-1 lg:col-span-8 lg:animate-blurred-fade-in lg:animate-duration-400 ease-in lg:animate-delay-150
					xl:col-span-9
					2xl:col-span-9"
				>
					<div
						class="flex flex-col justify-around items-center p-12 gap-10
						md:gap-14 md:p-10
						lg:gap-8
						xl:gap-16 xl:items-center xl:p-14
						2xl:flex-row"
					>
						<article
							class="prose prose-sm text-font-primary
							md:prose-base
							xl:prose-lg"
						>
							<h2
								class="text-blue-900 font-semibold dark:text-blue-300"
							>
								Full Stack Engineer
							</h2>
							<h4 class="text-font-primary">
								With a Data Engineering heart & UX soul
							</h4>
							<p class="text-font-secondary">
								I don&apos;t just move data. I build the systems
								that make it valuable. Specialized in scalable
								pipelines and distributed architectures, with
								the technical edge to transform backend
								complexity into exceptional analytical
								interfaces.
							</p>
						</article>
						<div
							class="flex flex-col sm:flex-row lg:flex-col justify-between gap-6"
						>
							<BtnBlue icon="/sprite.svg#arrow" href="#projects"
								>View projects
							</BtnBlue>
							<span
								class="hidden 2xl:block text-center text-xl text-font-secondary"
								>or</span
							>
							<BtnGeneric
								icon="/sprite.svg#message"
								href="#contact"
								>Contact me
							</BtnGeneric>
						</div>
					</div>
				</GlassBox>
			</div>
		</section>
		<section
			id="stack"
			class="max-w-7xl mx-auto w-full pt-14"
			aria-label="Stack"
		>
			<h2
				class="text-xl md:text-2xl uppercase tracking-[0.2em] text-gray-500 dark:text-slate-200 py-8 px-2 flex items-center gap-2
				relative w-fit
				lg:timeline-view animate-blurred-fade-in animate-range-[entry_5%_contain_10%]"
			>
				<div
					class="absolute inset-0 bg-bg/10 blur-xl overflow-visible -z-10"
				>
				</div>
				<span
					class="w-2 h-2 rounded-full bg-green-500 shadow-[0_0_8px_rgba(249,115,22,0.5)]"
				></span>
				Stack
			</h2>

			<div
				class="flex flex-col xl:flex-row md:items-start justify-center gap-6"
			>
				<GlassBox
					class="flex-1 flex flex-col items-center p-6 text-font-primary xl:place-self-stretch
					lg:timeline-view lg:animate-blurred-fade-in lg:animate-range-[entry_5%_contain_10%]"
				>
					<h3
						class="font-light text-2xl tracking-wider text-font-primary mb-6 flex items-center"
					>
						Data Engineering
					</h3>
					<div class="grid grid-cols-4 gap-8">
						{
							dataEngineering?.data.skills.map((skill) => (
								<div class="flex flex-col">
									<svg class="h-20 filter drop-shadow-[0_0_4px_rgba(100,100,100,0.4)] dark:drop-shadow-[0_0_4px_rgba(255,255,255,0.6)] overflow-visible">
										<use
											xlink:href={`/sprite.svg#${skill.icon}`}
										/>
									</svg>
									<span class="text-center text-sm font-medium pt-4 h-16">
										{skill.name}
									</span>
								</div>
							))
						}
					</div>
				</GlassBox>

				<GlassBox
					class="flex-1 flex flex-col items-center p-6 text-font-primary
					lg:timeline-view lg:animate-blurred-fade-in lg:animate-range-[entry_5%_contain_10%]"
				>
					<h3
						class="font-light text-2xl tracking-wider text-font-primary mb-6 flex items-center"
					>
						Software Development
					</h3>
					<div class="grid grid-cols-4 gap-8">
						{
							softwareDevelopment?.data.skills.map((skill) => (
								<div class="flex flex-col">
									<svg class="h-20 filter drop-shadow-[0_0_4px_rgba(100,100,100,0.4)] dark:drop-shadow-[0_0_4px_rgba(255,255,255,0.6)] overflow-visible">
										<use
											xlink:href={`/sprite.svg#${skill.icon}`}
										/>
									</svg>
									<span
										class="text-center text-sm font-semibold pt-4 h-16
													"
									>
										{skill.name}
									</span>
								</div>
							))
						}
					</div>
				</GlassBox>

				<GlassBox
					class="flex-1 flex flex-col items-center p-6 text-font-primary
					lg:timeline-view lg:animate-blurred-fade-in lg:animate-range-[entry_5%_contain_10%]"
				>
					<h3
						class="font-light text-2xl tracking-wider text-font-primary mb-6 flex items-center"
					>
						Cloud & Infrastructure
					</h3>
					<div class="grid gap-8 grid-cols-4">
						{
							cloudInfrastructure?.data.skills.map((skill) => (
								<div class="flex flex-col">
									<svg class="h-20 filter drop-shadow-[0_0_4px_rgba(100,100,100,0.4)] dark:drop-shadow-[0_0_4px_rgba(255,255,255,0.6)] overflow-visible">
										<use
											xlink:href={`/sprite.svg#${skill.icon}`}
										/>
									</svg>
									<span class="text-center text-sm font-semibold pt-4 h-16">
										{skill.name}
									</span>
								</div>
							))
						}
					</div>
				</GlassBox>
			</div>
		</section>
		<section
			id="projects"
			class="max-w-7xl mx-auto w-full pt-14"
			aria-label="Projects"
		>
			<h2
				class="text-xl md:text-2xl uppercase tracking-[0.2em] text-slate-500 dark:text-slate-300 py-8 px-2 flex items-center gap-2 relative w-fit
				lg:timeline-view lg:animate-blurred-fade-in lg:animate-range-[entry_50%_contain_20%]"
			>
				<div class="absolute inset-0 bg-bg/10 blur-xl -z-10"></div>
				<span
					class="w-2 h-2 rounded-full bg-orange-500 shadow-[0_0_8px_rgba(249,115,22,0.5)]"
				></span>
				Projects
			</h2>
			<div class="grid grid-cols-1 xl:grid-cols-3 gap-6 md:gap-10">
				{
					mainProject && (
						<GlassBox
							class="xl:col-span-2 p-8 md:p-12 flex flex-col justify-between h-full min-h-[400px]
						lg:timeline-view lg:animate-blurred-fade-in lg:animate-range-[entry_5%_entry_50%]"
						>
							<div class="flex flex-col h-full items-start">
								<h3 class="text-3xl md:text-4xl font-bold text-font-primary">
									{mainProject.data.title}
								</h3>
								<p class="mt-6 text-lg text-font-secondary grow">
									{mainProject.data.description}
								</p>
								<div class="flex flex-wrap gap-3 mt-6 mb-10">
									{mainProject.data.tags.map((tag) => (
										<span class="px-3 py-1 bg-white/20 dark:bg-white/10 rounded-full text-sm text-font-primary shadow-sm font-medium">
											{tag}
										</span>
									))}
								</div>
								<div class="mt-auto">
									<BtnBlue
										icon="/sprite.svg#arrow"
										href={mainProject.data.link}
									>
										Check Out
									</BtnBlue>
								</div>
							</div>
						</GlassBox>
					)
				}

				<div
					class="grid grid-cols-1 md:grid-cols-3 xl:grid-cols-1 gap-6 md:gap-10 xl:col-span-1"
				>
					{
						secondaryProjects.map((proj) => (
							<GlassBox
								class="p-6 md:p-8 flex flex-col justify-between h-full min-h-[250px]
							lg:timeline-view lg:animate-blurred-fade-in lg:animate-range-[entry_5%_contain_30%]"
							>
								<div class="flex flex-col h-full items-start">
									<h3 class="text-xl md:text-2xl font-bold text-font-primary">
										{proj.data.title}
									</h3>
									<p class="mt-3 text-sm md:text-base text-font-secondary grow line-clamp-3">
										{proj.data.description}
									</p>
									<div class="flex flex-wrap gap-2 mt-4 mb-6">
										{proj.data.tags.map((tag: any) => (
											<span class="px-2 py-1 bg-white/20 dark:bg-white/10 rounded-full text-xs text-font-primary shadow-sm">
												{tag}
											</span>
										))}
									</div>
									<div class="mt-auto">
										<BtnGeneric
											icon="/sprite.svg#arrow"
											href={proj.data.link}
										>
											Go to
										</BtnGeneric>
									</div>
								</div>
							</GlassBox>
						))
					}
				</div>
			</div>
		</section>
		<section
			id="experience"
			class="max-w-7xl mx-auto w-full pt-14"
			aria-label="Experience"
		>
			<h2
				class="text-xl md:text-2xl uppercase tracking-[0.2em] text-slate-500 dark:text-slate-300 py-8 px-2 flex items-center gap-2 relative w-fit
				lg:timeline-view lg:animate-blurred-fade-in lg:animate-range-[entry_50%_contain_40%]"
			>
				<div class="absolute inset-0 bg-bg/10 blur-xl -z-10"></div>
				<span
					class="w-2 h-2 rounded-full bg-blue-500 shadow-[0_0_8px_rgba(59,130,246,0.5)]"
				></span>
				Experience
			</h2>
			<div
				class="flex flex-col xl:flex-row md:items-stretch justify-center gap-6 md:gap-6"
			>
				{
					allExperiences.slice(0, 2).map((exp) => (
						<GlassBox
							class="flex-1 p-6 md:p-8 flex flex-col items-start xl:place-self-stretch min-h-[250px]
						lg:timeline-view lg:animate-blurred-fade-in lg:animate-range-[entry_5%_contain_30%]"
						>
							<h3 class="text-2xl font-bold text-font-primary">
								{exp.data.title}
							</h3>
							<h4 class="text-lg font-semibold text-blue-600 dark:text-blue-400 mt-2">
								{exp.data.company}
							</h4>
							<p class="mt-4 text-base text-font-secondary grow leading-relaxed">
								{exp.data.description}
							</p>
						</GlassBox>
					))
				}

				<GlassBox
					class="flex-1 p-6 md:p-8 flex flex-col items-start xl:place-self-stretch min-h-[250px]
					lg:timeline-view lg:animate-blurred-fade-in lg:animate-range-[entry_5%_contain_30%]"
				>
					<h3
						class="font-light text-2xl tracking-wider text-font-primary mb-6 flex items-center w-full"
					>
						Workflow
					</h3>
					<div class="flex flex-col gap-4 w-full">
						{
							mainExperience &&
								Object.entries(
									mainExperience.data.methodologies,
								).map(([key, value]) => (
									<div class="flex flex-col w-full border-b border-gray-200/20 dark:border-white/10 last:border-0 pb-3 last:pb-0">
										<h4 class="text-md md:text-lg font-bold text-font-primary mb-1">
											{key}
										</h4>
										<p class="text-sm text-font-secondary">
											{value}
										</p>
									</div>
								))
						}
					</div>
				</GlassBox>
			</div>
		</section>
		<section
			id="contact"
			class="max-w-7xl mx-auto w-full py-14"
			aria-label="Contact"
		>
			<h2
				class="text-xl md:text-2xl uppercase tracking-[0.2em] text-slate-500 dark:text-slate-300 py-8 px-2 flex items-center gap-2 relative w-fit"
			>
				<div class="absolute inset-0 bg-bg/10 blur-xl -z-10"></div>
				<span
					class="w-2 h-2 rounded-full bg-red-500 shadow-[0_0_8px_rgba(239,68,68,0.5)]"
				></span>
				Contact
			</h2>

			<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
				<!-- CV Box -->
				<a
					href="/resume.pdf"
					target="_blank"
					class="order-1 lg:order-2 lg:col-span-1 group/cv block outline-none"
				>
					<GlassBox
						class="h-full p-8 flex flex-col justify-center items-center gap-4 transition-colors group-hover/cv:bg-white/10 dark:group-hover/cv:bg-white/5 min-h-[160px]
						lg:timeline-view lg:animate-blurred-fade-in lg:animate-range-[entry_5%_contain_30%]"
					>
						<svg
							class="w-12 h-12 text-font-primary group-hover/cv:text-blue-400 group-hover/cv:scale-110 transition-all duration-300"
						>
							<use xlink:href="/sprite.svg#document"></use>
						</svg>
						<span
							class="font-bold text-lg tracking-widest text-font-primary group-hover/cv:text-blue-400 transition-colors"
						>
							DOWNLOAD RESUME
						</span>
					</GlassBox>
				</a>

				<!-- Form Box -->
				<GlassBox
					class="order-2 lg:order-1 lg:col-span-2 lg:row-span-2 p-8 md:p-12 flex flex-col justify-center min-h-[350px]
					lg:timeline-view lg:animate-blurred-fade-in lg:animate-range-[entry_5%_contain_30%]"
				>
					<h3
						class="text-2xl md:text-3xl font-bold text-font-primary mb-8"
					>
						Let's work together
					</h3>
					<form action="#" class="flex flex-col gap-5">
						<div class="flex flex-col md:flex-row gap-5">
							<input
								type="text"
								placeholder="Name"
								class="w-full bg-input-bg border border-white/15 rounded-xl px-5 py-4 outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all text-font-primary placeholder-gray-500"
								required
							/>
							<input
								type="email"
								placeholder="Email"
								class="w-full bg-input-bg border border-white/15 rounded-xl px-5 py-4 outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all text-font-primary placeholder-gray-500"
								required
							/>
						</div>
						<textarea
							placeholder="Message"
							rows="4"
							class="w-full bg-input-bg border border-white/15 rounded-xl px-5 py-4 outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all text-font-primary placeholder-gray-500 resize-none"
							required></textarea>
						<div
							class="mt-4 self-center md:self-start w-full md:w-auto"
						>
							<button
								type="submit"
								class="group/btn-blue bg-blue-600 dark:bg-blue-600 px-6 py-4 rounded-xl shadow-glow-sm dark:shadow-glow-md shadow-blue-400/80 hover:scale-105 transition-transform w-full md:w-60 text-center relative inset-shadow-sm inset-shadow-white/30 duration-100 border-0 outline-none cursor-pointer flex justify-center items-center"
							>
								<span
									class="font-semibold tracking-wider font-sans text-sm lg:text-base text-white inline-flex flex-row items-center justify-center gap-2 uppercase"
								>
									<span class="transition-all"
										>Send Message</span
									>
									<svg
										width="18"
										height="18"
