---
import GlassBox from "../components/container/GlassBox.astro";
import Section from "../components/common/Section.astro";
import { getEntry } from "astro:content";

const dataEngineering = await getEntry("categories", "dataengineering");
const softwareDevelopment = await getEntry("categories", "softwaredevelopment");
const cloudInfrastructure = await getEntry("categories", "cloudinfrastructure");
---

<Section title="Stack" class="lg:pb-20">
    <div class="flex flex-col xl:flex-row md:items-start justify-center gap-6">
        <GlassBox
            class="flex-1 flex flex-col items-center p-6 text-font-primary xl:place-self-stretch
					lg:timeline-view lg:animate-blurred-fade-in lg:animate-range-[entry_5%_contain_10%]"
        >
            <h3
                class="font-light text-2xl tracking-wider text-font-primary mb-6 flex items-center"
            >
                Data Engineering
            </h3>
            <div class="grid grid-cols-4 gap-8">
                {
                    dataEngineering?.data.skills.map((skill) => (
                        <div class="flex flex-col">
                            <svg class="h-20 filter drop-shadow-[0_0_4px_rgba(100,100,100,0.4)] dark:drop-shadow-[0_0_4px_rgba(255,255,255,0.6)] overflow-visible">
                                <use xlink:href={`/sprite.svg#${skill.icon}`} />
                            </svg>
                            <span class="text-center text-sm font-medium pt-4 h-16">
                                {skill.name}
                            </span>
                        </div>
                    ))
                }
            </div>
        </GlassBox>

        <GlassBox
            class="flex-1 flex flex-col items-center p-6 text-font-primary
					lg:timeline-view lg:animate-blurred-fade-in lg:animate-range-[entry_5%_contain_10%]"
        >
            <h3
                class="font-light text-2xl tracking-wider text-font-primary mb-6 flex items-center"
            >
                Software Development
            </h3>
            <div class="grid grid-cols-4 gap-8">
                {
                    softwareDevelopment?.data.skills.map((skill) => (
                        <div class="flex flex-col">
                            <svg class="h-20 filter drop-shadow-[0_0_4px_rgba(100,100,100,0.4)] dark:drop-shadow-[0_0_4px_rgba(255,255,255,0.6)] overflow-visible">
                                <use xlink:href={`/sprite.svg#${skill.icon}`} />
                            </svg>
                            <span
                                class="text-center text-sm font-semibold pt-4 h-16
													"
                            >
                                {skill.name}
                            </span>
                        </div>
                    ))
                }
            </div>
        </GlassBox>

        <GlassBox
            class="flex-1 flex flex-col items-center p-6 text-font-primary
					lg:timeline-view lg:animate-blurred-fade-in lg:animate-range-[entry_5%_contain_10%]"
        >
            <h3
                class="font-light text-2xl tracking-wider text-font-primary mb-6 flex items-center"
            >
                Cloud & Infrastructure
            </h3>
            <div class="grid gap-8 grid-cols-4">
                {
                    cloudInfrastructure?.data.skills.map((skill) => (
                        <div class="flex flex-col">
                            <svg class="h-20 filter drop-shadow-[0_0_4px_rgba(100,100,100,0.4)] dark:drop-shadow-[0_0_4px_rgba(255,255,255,0.6)] overflow-visible">
                                <use xlink:href={`/sprite.svg#${skill.icon}`} />
                            </svg>
                            <span class="text-center text-sm font-semibold pt-4 h-16">
                                {skill.name}
                            </span>
                        </div>
                    ))
                }
            </div>
        </GlassBox>
    </div>
</Section>
