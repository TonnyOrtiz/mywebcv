---
interface Props {
    class?: string;
    // Puedes añadir más props aquí
    [key: string]: any; // Esto permite recibir cualquier otro atributo (id, data-*, etc)
}
const { class: className = "", ...rest } = Astro.props;
---

<div
    class:list={[
        `col-span-1 relative group overflow-hidden rounded-xl
        white/20 dark:bg-mg/10 
        backdrop-blur-md shadow-2xl z-0
        `,
        className,
    ]}
    {...rest}
>
    <div
        class="bg-mg opacity-100 absolute inset-0 pointer-events-none z-10
        inset-shadow-xs inset-shadow-white/40 dark:inset-shadow-white/10"
    >
    </div>

    <div
        class="relative
        z-20
        flex-3
        flex
        flex-col
        col-span-1 md:col-span-3
        text-font-primary
        min-h-full
        gap-4
        md:gap-0
        md:justify-around"
    >
        <slot />
    </div>
</div>
