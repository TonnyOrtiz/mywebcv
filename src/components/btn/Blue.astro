---
interface Props {
    icon?: string;
}

const { icon } = Astro.props;
---

<a
    class=""
    href="https://www.linkedin.com/in/tonny-ortiz/"
    target="_blank"
    aria-label="Contact me"
    title="Contact me"
>
    <div
        class="group/btn-blue bg-blue-600 dark:bg-blue-600 px-4 py-4 rounded-xl animate-slide-up-fade animate-delay-400
    shadow-glow-sm dark:shadow-glow-md shadow-blue-400/80 hover:scale-110 transition-transform w-60 md:w-74 text-center relative
    inset-shadow-sm inset-shadow-white/30"
    >
        <span
            class="font-semibold tracking-wider font-sans text-sm md:text-lg text-white inline-flex flex-row items-center gap-2 uppercase"
        >
            <span class="transition-all"><slot /></span>
            {
                icon ? (
                    <svg
                        width="18"
                        height="18"
                        class="blue-btn-icon group-hover/btn-blue:translate-x-2
                        transition-transform duration-300
                        "
                    >
                        <use xlink:href={icon} />
                    </svg>
                ) : null
            }
        </span>
    </div>
</a>
